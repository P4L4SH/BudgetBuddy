{
  "name": "budgetbuddy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"node server/server.js\" \"npm --prefix client run dev\"",
    "build": "npm --prefix client run build",
    "start": "node server/server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
